# Copy this file to .streamlit/secrets.toml for local Streamlit testing
# or paste the values into Streamlit Community Cloud App Settings -> Secrets.

PINECONE_API_KEY = "pc-..."
OPENAI_API_KEY = "sk-..."
OWNER_OPENAI_API_KEY = "sk-..."
SESSION_SECRET = "..."

PINECONE_INDEX = "recipes-vector-db"
PINECONE_NAMESPACE = "main_recipes"
EMBEDDING_MODEL = "text-embedding-3-small"
SPARSE_HASH_DIM = "262144"
SPARSE_MIN_DOC_FREQ = "1"
MATCH_THRESHOLD = "0.10"
SPARSE_THRESHOLD = "0.0"
MIN_DENSE_HITS = "3"
DENSE_TOP_K = "10"
SPARSE_TOP_K = "10"
